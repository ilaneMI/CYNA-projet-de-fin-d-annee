# Copier en .env.local et remplir les valeurs.
# .env.local est git-ignored ; ce fichier (.env.example) est versionné, ne jamais y mettre de vraie valeur.
# Sous Next.js, les variables exposées au navigateur DOIVENT commencer par NEXT_PUBLIC_.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Côté serveur uniquement (Edge Functions, scripts). Ne JAMAIS exposer côté client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Côté serveur uniquement.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- PayPal (référencé dans src/lib/stripe.ts) ---
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
